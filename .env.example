# Base de datos (MySQL / MariaDB)
DATABASE_URL="mysql://user:password@localhost:3306/chasoft"
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=chasoft_user
DATABASE_PASSWORD=tu_contraseña
DATABASE_NAME=chasoft

