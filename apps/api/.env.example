# Copia a .env y rellena los valores (cp .env.example .env)
# Base de datos (MySQL / MariaDB)
DATABASE_URL="mysql://user:password@localhost:3306/database_name"
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=

# Si la app no conecta por puerto (pool timeout), prueba por socket (Mac/Homebrew):
# DATABASE_SOCKET=/tmp/mysql.sock

# Servidor
PORT=3000

# Auth (cambiar en producción)
JWT_SECRET=change-me-in-production-min-32-chars
# JWT_EXPIRES_IN=7d

# CORS: origen permitido (frontend). Por defecto http://localhost:3001
# CORS_ORIGIN=http://localhost:3001
