{
  "name": "@chax/api",
  "version": "1.0.0",
  "private": true,
  "description": "Chax API - Backend",
  "engines": {
    "node": "^20.19 || ^22.12 || >=24.0"
  },
  "scripts": {
    "dev": "NODE_OPTIONS='--experimental-wasm-reftypes' npx ts-node-dev --respawn --transpile-only src/infrastructure/http/server.ts",
    "build": "tsc",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@chax/shared": "*",
    "bcryptjs": "^2.4.3",
    "@prisma/adapter-mariadb": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "mariadb": "^3.5.1",
    "prisma": "^7.4.2",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
